# Get your free WalletConnect Project ID at https://cloud.walletconnect.com/
# This is required for wallet connections to work properly
VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Network Configuration
# Set to 31337 for localhost or 11155111 for sepolia
VITE_ACTIVE_CHAIN_ID=31337

# RPC URLs
VITE_LOCAL_RPC_URL=http://127.0.0.1:8545
VITE_SEPOLIA_RPC_URL=https://rpc.sepolia.org

# Contract Addresses (update these after deployment)
VITE_CIPHERVAULT_ADDRESS_LOCALHOST=0x5FbDB2315678afecb367f032d93F642f64180aa3
VITE_CIPHERVAULT_ADDRESS_SEPOLIA=0x0000000000000000000000000000000000000000

# FHE Relayer URL for encryption
VITE_FHE_RELAYER_URL=http://127.0.0.1:8545/fhe
